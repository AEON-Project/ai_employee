# ai-emp · 项目配置环境变量样板
#
# 复制为 .env（Bun 启动时自动加载；.env 已在 .gitignore 内）：
#   cp .env.example .env
#
# 优先级：.env > ~/.ai-emp/config.toml > 内置默认。
# 所有变量都是可选；不设则走 toml/默认。
#
# 注：凭证（LLM key / TG bot token / localhost token）**不**通过 .env 传，
# 一律走 OS keychain：`ai-emp keychain set <name>`。
# .env 只放"指向凭证的 key 名"和"非敏感配置"。

# ── 数据目录 ─────────────────────────────────────────────────
# 默认 ~/.ai-emp/。开发期可指向项目内子目录：
# AIEMP_DATA_DIR=./.ai-emp-data

# ── LLM 配置（开发用 .env；生产建议 key 走 keychain，其余字段写死） ──
#
# 员工有 3 个字段都能写成 `env://NAME` 引用 .env：
#   modelKeyRef    → API key（也支持 keychain 名）
#   modelBaseUrl   → API 端点（OpenAI 兼容协议用）
#   modelName      → 模型 ID
#
# 例 1）员工挂 Claude：
#   modelProvider = anthropic
#   modelKeyRef   = env://AIEMP_ANTHROPIC_API_KEY
#   modelName     = env://AIEMP_ANTHROPIC_MODEL
#   modelBaseUrl  = (留空，Anthropic SDK 默认)
#
# AIEMP_ANTHROPIC_API_KEY=sk-ant-xxxxx
# AIEMP_ANTHROPIC_MODEL=claude-opus-4-7
#
# 例 2）员工挂 OpenAI 原生：
#   modelProvider = openai-compat
#   modelKeyRef   = env://AIEMP_OPENAI_API_KEY
#   modelBaseUrl  = env://AIEMP_OPENAI_BASE_URL  （或留空走 SDK 默认）
#   modelName     = env://AIEMP_OPENAI_MODEL
#
# AIEMP_OPENAI_API_KEY=sk-xxxxx
# AIEMP_OPENAI_BASE_URL=https://api.openai.com/v1
# AIEMP_OPENAI_MODEL=gpt-4o
#
# 例 3）员工挂 DeepSeek（OpenAI 兼容协议）：
#   modelProvider = openai-compat
#   modelKeyRef   = env://AIEMP_DEEPSEEK_API_KEY
#   modelBaseUrl  = env://AIEMP_DEEPSEEK_BASE_URL
#   modelName     = env://AIEMP_DEEPSEEK_MODEL
#
# AIEMP_DEEPSEEK_API_KEY=sk-xxxxx
# AIEMP_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# AIEMP_DEEPSEEK_MODEL=deepseek-chat
#
# 例 4）员工挂 Kimi / 智谱 等：同 DeepSeek 模式，命名约定
#   AIEMP_<UPPER>_API_KEY / _BASE_URL / _MODEL
#
# AIEMP_MOONSHOT_API_KEY=sk-xxxxx
# AIEMP_MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# AIEMP_MOONSHOT_MODEL=moonshot-v1-32k
#
# 嵌入模型走 transformers.js 本地推理，**不需要** API key。

# ── HTTP 服务 ────────────────────────────────────────────────
# AIEMP_PORT=7878
# AIEMP_LOCALHOST_TOKEN_REF=localhost-token

# ── 嵌入模型 ─────────────────────────────────────────────────
# AIEMP_EMBEDDING_MODEL=bge-small-zh-v1.5
# AIEMP_EMBEDDING_DIM=512

# ── Telegram bridge（可选；不配则 bridge 不启动） ────────────
# 1) 先 `ai-emp keychain set tg-bot-token <BOT_TOKEN>` 写入 token；
# 2) 这里指定 keychain 的 key 名 + 白名单 chat id：
# AIEMP_TG_BOT_TOKEN_REF=tg-bot-token
# AIEMP_TG_CHAT_IDS=12345678,87654321

# ── 需求默认 Budget Cap ─────────────────────────────────────
# AIEMP_BUDGET_MAX_ITERATIONS=30
# AIEMP_BUDGET_MAX_TOKENS=200000
# AIEMP_BUDGET_MAX_WALL_TIME_MS=1800000

# ── 临时凭证（仅用于 `ai-emp keychain set` 时的 stdin 替代） ──
# 不要长期写在 .env；用完即删。
# AIEMP_SECRET=
